{
  "name": "mikeroguez",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run generate:blog && npm run generate:research && vue-tsc --noEmit && vite build && node scripts/create-pages-fallback.mjs",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check:public": "node scripts/check-public-safety.mjs",
    "generate:blog": "node scripts/generate-blog-content.mjs",
    "generate:research": "node scripts/generate-research-content.mjs",
    "optimize:brand": "node scripts/optimize-brand-logo.mjs",
    "validate": "npm run generate:blog && npm run generate:research && npm run format:check && npm run lint && npm run typecheck && npm run test:run && npm run check:public && npm run build"
  },
  "dependencies": {
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vitest/coverage-v8": "^3.2.0",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.5.0",
    "@vue/test-utils": "^2.4.0",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.30.0",
    "eslint-plugin-vue": "^10.2.0",
    "jsdom": "^26.1.0",
    "markdown-it": "^14.3.0",
    "prettier": "^3.6.0",
    "svgo": "^4.0.2",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^3.2.0",
    "vue-tsc": "^2.2.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
